{
  "name": "clientapp",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "run-p type-check build-only",
    "build-only": "vite build",
    "dev": "run-p type-check dev-only",
    "dev-only": "vite",
    "watch": "run-p type-check watch-only",
    "watch-only": "vite build --watch --mode development",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "eslint . --fix",
    "generate-api-client": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 sta generate -p https://localhost:5001/swagger/v1/swagger.json -o ./src/api/ --modular --responses --extract-request-params && node scripts/fix-api-files.js && node scripts/fix-api-files.js",
    "clean-api": "node scripts/fix-api-files.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.2.0",
    "@popperjs/core": "^2.11.8",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-typography": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "@tiptap/vue-3": "^3.22.4",
    "@vueuse/core": "^14.2.1",
    "bootstrap": "^5.3.8",
    "date-fns": "^4.1.0",
    "js-beautify": "^1.15.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-color": "^3.3.3",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@tsconfig/node18": "^18.2.6",
    "@types/bootstrap": "^5.2.10",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "npm-check-updates": "^21.0.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.99.0",
    "swagger-typescript-api": "^13.6.10",
    "typescript": "~6.0.3",
    "vite": "^8.0.8",
    "vue-tsc": "^3.2.6"
  }
}
